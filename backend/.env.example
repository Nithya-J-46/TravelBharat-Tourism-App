# TravelBharat Backend Environment Variables

# Port configuration
PORT=5000

# MongoDB Connection String (Atlas URI in production)
# Example: mongodb+srv://<username>:<password>@cluster.mongodb.net/travelbharat?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/travelbharat

# JWT Authentication Secret Key (Required for session signing in production)
JWT_SECRET=travelbharat_super_secret_key_123456

# Frontend domain URL for CORS configuration (optional, defaults to * if omitted)
# Example: https://travelbharat.vercel.app
FRONTEND_URL=http://localhost:5173
